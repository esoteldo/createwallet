{
    "name": "@cryptolottery/wallet",
    "version": "0.1.0",
    "description": "TON HighloadWalletV3 library + Blueprint tooling for CryptoLottery payouts",
    "main": "dist/src/index.js",
    "types": "dist/src/index.d.ts",
    "files": [
        "dist",
        "contracts",
        "wrappers",
        "src"
    ],
    "scripts": {
        "bp": "blueprint",
        "start": "blueprint run",
        "blueprint:build": "blueprint build",
