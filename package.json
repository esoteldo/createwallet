        "release": "npm run build && blueprint pack && npm publish --access public"
    },
    "dependencies": {
        "@ton/core": "~0",
        "@ton/crypto": "^3.3.0",
        "@ton/ton": ">=15.3.1 <16.0.0"
    },
    "devDependencies": {
        "@ton/blueprint": ">=0.40.0",
        "@ton/sandbox": ">=0.37.0",
        "@ton/test-utils": ">=0.11.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.17.2",
        "jest": "^30.0.5",
        "prettier": "^3.6.2",
        "ts-jest": "^29.4.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.2",
        "@ton/tolk-js": ">=1.0.0",
        "@tact-lang/compiler": ">=1.6.13 <2.0.0",
        "@ton-community/func-js": ">=0.10.0"
    }
